# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Database (Supabase / PostgreSQL connection string)
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-16-chars
OTP_TTL_MINUTES=10

# Brevo (transactional email API)
RESEND_API_KEY=
EMAIL_FROM="BunziMeal <no-reply@bunzimeal.com>"

# Cloudinary (cloudinary://api_key:api_secret@cloud_name)
CLOUDINARY_URL=
CLOUDINARY_FOLDER=bunzimeal/uploads

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=
FRONTEND_BASE_URL=http://localhost:5173

# Currency conversion (Unirate API - Optional, falls back to exchangerate.host)
UNIRATE_API_KEY=
