{
  "name": "bunzimeal-api",
  "version": "1.0.0",
  "description": "BunziMeal API — mobile-first meal planning backend",
  "type": "module",
  "main": "src/server.ts",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/database/run.ts",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.15.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.15.6",
    "nodemon": "^3.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
